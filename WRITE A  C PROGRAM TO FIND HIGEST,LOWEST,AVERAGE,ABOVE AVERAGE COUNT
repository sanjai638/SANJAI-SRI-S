     #include <stdio.h>

int main() {
    int N, i, highest, lowest, aboveAverageCount = 0;
    float average, sum = 0.0;

    scanf("%d", &N);
    int marks[N];

    for (i = 0; i < N; i++) {
        scanf("%d", &marks[i]);
        sum += marks[i];
    }

    highest = marks[0];
    lowest = marks[0];

    for (i = 0; i < N; i++) {
        if (marks[i] > highest) {
            highest = marks[i];
        }
        if (marks[i] < lowest) {
            lowest = marks[i];
        }
    }

    average = sum / N;

    for (i = 0; i < N; i++) {
        if (marks[i] > average) {
            aboveAverageCount++;
        }
    }

    printf("Highest: %d\n", highest);
    printf("Lowest: %d\n", lowest);
    printf("Average: %.2f\n", average);
    printf("Above Average Count: %d\n", aboveAverageCount);

    return 0;
}
