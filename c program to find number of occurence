#include <stdio.h>
#include <string.h>

int main() {
    char S[100001];
    scanf("%s", S);

    int len = strlen(S);
    int count = 1;

    for (int i = 0; i < len; i++) {
        if (i < len - 1 && S[i] == S[i + 1]) {
            count++;
        } else {
            printf("%c", S[i]);
            if (count > 1) {
                printf("%d", count);
            }
            count = 1;
        }
    }

    return 0;
}
